# ---- invoice-service configuration ----
SERVICE_NAME=invoice-service
NODE_ENV=production
PORT=4004

# Postgres backing service
CDS_REQUIRES_DB_KIND=postgres
CDS_REQUIRES_DB_CREDENTIALS_HOST=postgres
CDS_REQUIRES_DB_CREDENTIALS_PORT=5432
CDS_REQUIRES_DB_CREDENTIALS_USER=vip_app
CDS_REQUIRES_DB_CREDENTIALS_PASSWORD=vip_app_pw
CDS_REQUIRES_DB_CREDENTIALS_DATABASE=invoicedb

# Downstream service (attached resource)
VENDOR_SERVICE_URL=http://vendor-service:4004/odata/v4/vendor

# Service-to-service credentials
SYSTEM_USER=system
SYSTEM_PASSWORD=system-secret
