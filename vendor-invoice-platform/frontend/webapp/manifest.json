{
  "_version": "1.59.0",
  "sap.app": {
    "id": "vendorinvoice.ui",
    "type": "application",
    "title": "Manage Invoices",
    "description": "Vendor Invoice Management",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "mainService": {
        "uri": "/invoice/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": { "sap.fe.templates": {} }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "vendorinvoice.ui.i18n.i18n", "supportedLocales": [""], "fallbackLocale": "" }
      },
      "": {
        "dataSource": "mainService",
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "routes": [
        { "pattern": ":?query:", "name": "InvoicesList", "target": "InvoicesList" },
        { "pattern": "Invoices({key}):?query:", "name": "InvoicesObjectPage", "target": "InvoicesObjectPage" }
      ],
      "targets": {
        "InvoicesList": {
          "type": "Component",
          "id": "InvoicesList",
          "name": "sap.fe.templates.ListReport",
          "options": { "settings": { "entitySet": "Invoices", "variantManagement": "None", "initialLoad": "Enabled" } }
        },
        "InvoicesObjectPage": {
          "type": "Component",
          "id": "InvoicesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": { "settings": { "entitySet": "Invoices" } }
        }
      }
    }
  },
  "sap.fiori": { "archeType": "transactional" }
}
