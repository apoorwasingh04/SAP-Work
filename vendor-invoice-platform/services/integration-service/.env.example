# ---- integration-service configuration ----
SERVICE_NAME=integration-service
NODE_ENV=production
PORT=4004

CDS_REQUIRES_DB_KIND=postgres
CDS_REQUIRES_DB_CREDENTIALS_HOST=postgres
CDS_REQUIRES_DB_CREDENTIALS_PORT=5432
CDS_REQUIRES_DB_CREDENTIALS_USER=vip_app
CDS_REQUIRES_DB_CREDENTIALS_PASSWORD=vip_app_pw
CDS_REQUIRES_DB_CREDENTIALS_DATABASE=integrationdb

# Downstream service
VENDOR_SERVICE_URL=http://vendor-service:4004/odata/v4/vendor

# Optional S/4HANA Business Partner API (leave S4_BASE_URL empty to use mock data)
S4_BASE_URL=
S4_USER=
S4_PASSWORD=

SYSTEM_USER=system
SYSTEM_PASSWORD=system-secret
