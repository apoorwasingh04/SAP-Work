{
  "_version": "1.59.0",
  "sap.app": {
    "id": "vendorinvoice.manageinvoices",
    "type": "application",
    "title": "Manage Invoices",
    "description": "Vendor Invoice Management",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "mainService": {
        "uri": "/admin/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0",
          "localUri": "localService/metadata.xml"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "manage-invoices-inbound": {
          "semanticObject": "Invoice",
          "action": "manage",
          "title": "Manage Invoices",
          "signature": { "parameters": {}, "additionalParameters": "allowed" }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.fe.templates": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "settings": { "synchronizationMode": "None", "operationMode": "Server", "autoExpandSelect": true, "earlyRequests": true }
      }
    },
    "routing": {
      "routes": [
        { "pattern": ":?query:", "name": "InvoicesList", "target": "InvoicesList" },
        { "pattern": "Invoices({key}):?query:", "name": "InvoicesObjectPage", "target": "InvoicesObjectPage" }
      ],
      "targets": {
        "InvoicesList": {
          "type": "Component",
          "id": "InvoicesList",
          "name": "sap.fe.templates.ListReport",
          "options": { "settings": { "entitySet": "Invoices", "variantManagement": "Page" } }
        },
        "InvoicesObjectPage": {
          "type": "Component",
          "id": "InvoicesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": { "settings": { "entitySet": "Invoices" } }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
