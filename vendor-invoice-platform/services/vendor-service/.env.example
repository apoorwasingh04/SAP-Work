# ---- vendor-service configuration (12-factor III: config in the environment) ----
SERVICE_NAME=vendor-service
NODE_ENV=production
PORT=4004

# Postgres backing service (attached resource - 12-factor IV)
CDS_REQUIRES_DB_KIND=postgres
CDS_REQUIRES_DB_CREDENTIALS_HOST=postgres
CDS_REQUIRES_DB_CREDENTIALS_PORT=5432
CDS_REQUIRES_DB_CREDENTIALS_USER=vip_app
CDS_REQUIRES_DB_CREDENTIALS_PASSWORD=vip_app_pw
CDS_REQUIRES_DB_CREDENTIALS_DATABASE=vendordb

# Service-to-service system credentials (used by callers of this service)
SYSTEM_USER=system
SYSTEM_PASSWORD=system-secret
